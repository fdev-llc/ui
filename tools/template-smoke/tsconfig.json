{
  "compilerOptions": {
    "allowJs": false,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "jsx": "react-native",
    "customConditions": ["react-native"],
    "module": "esnext",
    "moduleResolution": "bundler",
    "strict": true,
    "noImplicitAny": true,
    "noImplicitReturns": true,
    "noImplicitThis": true,
    "target": "esnext",
    "lib": ["esnext", "dom"],
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "noEmit": true,
    "types": ["node"],
    "baseUrl": "../..",
    "paths": {
      "@/components/*": ["templates/components/*"],
      "@/hooks/*": ["templates/hooks/*"],
      "@/theme/*": ["templates/theme/*"]
    }
  },
  "include": ["../../templates/components/**/*", "../../templates/hooks/**/*", "../../templates/theme/**/*"]
}
